# Redis
REDIS_URL=redis://localhost:6379

# Evolution API (dev: porta 8090 mapeada pelo docker-compose.dev.yml)
EVOLUTION_API_URL=http://localhost:8090
EVOLUTION_API_KEY=your-api-key-here
EVOLUTION_INSTANCE=laurinha

# Webhook secret (Evolution API → whatsapp-adapter)
WEBHOOK_SECRET=your-webhook-secret-here

# Core Backend (porta exposta no host)
CORE_PORT=3321

# WhatsApp Adapter (porta exposta no host)
WA_ADAPTER_PORT=3322

# PostgreSQL (dev: porta 5433 mapeada pelo docker-compose.dev.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/laurinha

# Dashboard
DASHBOARD_PORT=3323
WA_ADAPTER_URL=http://localhost:3322
CORE_BACKEND_URL=http://localhost:3321
